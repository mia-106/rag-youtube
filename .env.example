# ================================
# YouTube Agentic RAG系统 - 环境配置模板
# ================================
# 请复制此文件为 .env 并填入真实的 API Keys

# 🔥 Firecrawl配置
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_DEEP_RESEARCH_URL=https://api.firecrawl.dev/v1/deep-search

# 🧠 DeepSeek配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 🗄️ Superabase数据库配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# 🔍 OpenAI/嵌入模型配置
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# 🔄 Cohere重排序配置
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=rerank-english-v3.0

# 📊 LangSmith可观测性配置
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=youtube-agentic-rag

# ⚙️ 系统配置
LOG_LEVEL=INFO
MAX_RETRIES=3
BATCH_SIZE=100

# 🔍 检索配置
VECTOR_SEARCH_LIMIT=100
HYBRID_SEARCH_TOP_K=50
RERANK_TOP_K=5

# ⚡ 性能配置
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=10

# 📁 文件路径
DATA_DIR=./data
CACHE_DIR=./cache
LOGS_DIR=./logs
